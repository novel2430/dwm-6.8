+int updatecenterclock(void) {
+  char buf[sizeof centerclocktext];
+  time_t now;
+  struct tm tm;
+
+  if (!CENTER_CLOCK_ENABLED)
+    return 0;
+
+  now = time(NULL);
+  if (!localtime_r(&now, &tm))
+    return 0;
+
+  buf[0] = '\0';
+  strftime(buf, sizeof buf, CENTER_CLOCK_FORMAT, &tm);
+  if (!strcmp(centerclocktext, buf))
+    return 0;
+
+  snprintf(centerclocktext, sizeof centerclocktext, "%s", buf);
+  return 1;
+}
